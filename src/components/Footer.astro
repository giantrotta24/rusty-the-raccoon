---
import { Image } from 'astro:assets';
import instagramIcon from '../assets/images/instagram-icon.png';
import facebookIcon from '../assets/images/facebook-icon.png';
import youtubeIcon from '../assets/images/youtube-icon.png';

const socialLinks = [
  { label: 'Instagram', href: 'https://www.instagram.com/rusty_theraccoon/', icon: instagramIcon },
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/rustytheraccoonisscaredofthedark',
    icon: facebookIcon,
  },
  {
    label: 'YouTube',
    href: 'https://www.youtube.com/channel/UCOp3C0QBIaA5T6tU9N5aiCQ',
    icon: youtubeIcon,
  },
];
---

<footer class="site-footer section-teal">
  <div class="firefly-field" aria-hidden="true">
    <span class="firefly" style="left: 8%; top: 22%; animation-delay: 0s;"></span>
    <span class="firefly" style="left: 22%; top: 62%; animation-delay: 1.1s;"></span>
    <span class="firefly" style="left: 40%; top: 18%; animation-delay: 2s;"></span>
    <span class="firefly" style="left: 58%; top: 55%; animation-delay: 0.6s;"></span>
    <span class="firefly" style="left: 76%; top: 28%; animation-delay: 1.7s;"></span>
    <span class="firefly" style="left: 90%; top: 60%; animation-delay: 2.6s;"></span>
  </div>
  <div class="wrap footer-inner">
    <h2>Keep Up With Rusty</h2>
    <ul class="social-list">
      {
        socialLinks.map((link) => (
          <li>
            <a href={link.href} target="_blank" rel="noreferrer noopener" aria-label={link.label}>
              <Image src={link.icon} alt="" width={44} height={44} />
            </a>
          </li>
        ))
      }
    </ul>
    <p class="publisher">
      <a href="https://www.freshbeginningspublishing.com/" target="_blank" rel="noreferrer noopener">
        Fresh Beginnings Publishing
      </a>
    </p>
    <p class="site-credit">
      Site by <a href="https://giantrotta.dev" target="_blank" rel="noopener noreferrer">Gian Trotta</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    text-align: center;
    padding-block: clamp(3rem, 6vw, 4.5rem);
  }

  .footer-inner {
    position: relative;
    z-index: 1;
  }

  .social-list {
    display: flex;
    justify-content: center;
    gap: 1rem;
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
  }

  .social-list a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-cream-soft);
    box-shadow: var(--shadow-soft);
    transition: transform 0.15s ease;
  }

  .social-list a:hover {
    transform: translateY(-3px) scale(1.05);
  }

  .publisher {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    margin: 0;
  }

  .publisher a {
    color: var(--color-cream-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .site-credit {
    margin: 1rem 0 0;
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .site-credit a {
    color: inherit;
    text-decoration: none;
  }

  .site-credit a:hover {
    text-decoration: underline;
  }
</style>
