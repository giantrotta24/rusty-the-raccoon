---
import { Image } from 'astro:assets';
import raccoonLogo from '../assets/images/raccoon-logo-transparent.png';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Author', href: '/author' },
  { label: 'Activities', href: '/activities' },
  { label: 'Resources', href: '/resources' },
  { label: 'Videos', href: '/videos' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const linkFor = (item: (typeof navItems)[number]) => {
  const itemPath = item.href.replace(/\/$/, '') || '/';
  return { ...item, isActive: itemPath === currentPath };
};
---

<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="brand">
      <span class="brand-text">
        <span class="brand-title">Rusty the Raccoon</span>
        <span class="brand-byline">by Michelle Trotta</span>
      </span>
      <span class="peek-rusty">
        <Image src={raccoonLogo} alt="" width={193} height={287} loading="eager" />
      </span>
    </a>

    <nav class="site-nav desktop-nav" aria-label="Primary">
      <ul>
        {
          navItems.map((item) => {
            const { href, label, isActive } = linkFor(item);
            return (
              <li>
                <a href={href} aria-current={isActive ? 'page' : undefined}>
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <nav class="site-nav mobile-nav" aria-label="Primary">
      <details>
        <summary aria-label="Menu">
          <span class="burger" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="burger-label">Menu</span>
        </summary>
        <ul>
          {
            navItems.map((item) => {
              const { href, label, isActive } = linkFor(item);
              return (
                <li>
                  <a href={href} aria-current={isActive ? 'page' : undefined}>
                    {label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </details>
    </nav>
  </div>
</header>

<style>
  /* The header clips the oversized Rusty art at its bottom edge so he
     reads as peeking over the fold — same trick as the original site. */
  .site-header {
    background: var(--color-cream);
    border-bottom: 1px solid rgba(20, 76, 83, 0.1);
    position: relative;
    overflow: hidden;
    z-index: 40;
  }

  .header-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding-top: 1.4rem;
  }

  .brand {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-teal);
    flex-shrink: 0;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
  }

  .brand-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.45rem;
    line-height: 1.2;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .brand-byline {
    font-family: var(--font-script);
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-ink);
    align-self: flex-end;
    margin-top: 0.15rem;
  }

  .peek-rusty {
    display: block;
    width: 170px;
    margin-top: 0.4rem;
    margin-bottom: -118px; /* lower body clipped by the header edge */
  }

  .peek-rusty :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Desktop nav ---------------------------------------------------- */
  .desktop-nav {
    align-self: center;
    padding-block: 1rem;
  }

  .desktop-nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-nav a {
    display: block;
    padding: 0.5em 0.9em;
    border-radius: 999px;
    text-decoration: none;
    color: var(--color-teal);
    font-weight: 700;
    font-size: 0.95rem;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .site-nav a:hover {
    background: rgba(20, 76, 83, 0.08);
  }

  .site-nav a[aria-current='page'] {
    background: var(--color-teal);
    color: var(--color-white);
  }

  /* Mobile nav (zero-JS disclosure) --------------------------------- */
  .mobile-nav {
    display: none;
  }

  .mobile-nav summary {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    padding: 0.6rem 0.9rem;
    border-radius: 999px;
    color: var(--color-teal);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    -webkit-tap-highlight-color: transparent;
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav summary:hover,
  .mobile-nav details[open] summary {
    background: rgba(20, 76, 83, 0.08);
  }

  .burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 20px;
  }

  .burger span {
    height: 2.5px;
    border-radius: 2px;
    background: currentColor;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  .mobile-nav details[open] .burger span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .mobile-nav details[open] .burger span:nth-child(2) {
    opacity: 0;
  }

  .mobile-nav details[open] .burger span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .mobile-nav ul {
    position: absolute;
    right: 1rem;
    margin: 0.4rem 0 0;
    padding: 0.6rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 190px;
    background: var(--color-cream-soft);
    border: 1px solid rgba(20, 76, 83, 0.12);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    z-index: 50;
  }

  .mobile-nav a {
    font-size: 1.05rem;
    padding: 0.55em 0.9em;
  }

  /* Breakpoints ------------------------------------------------------ */
  @media (max-width: 820px) {
    .desktop-nav {
      display: none;
    }

    .mobile-nav {
      display: block;
      align-self: center;
    }

    /* The dropdown must escape the header's clipping box, so on mobile
       the header stops clipping and Rusty peeks a shorter distance. */
    .site-header {
      overflow: visible;
    }

    .header-inner {
      padding-top: 1rem;
      align-items: center;
      gap: 0.75rem;
    }

    .brand {
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(0.4rem, 2vw, 0.8rem);
      min-width: 0; /* let the brand shrink instead of pushing the menu off-canvas */
      flex-shrink: 1; /* desktop rule pins it at 0 */
    }

    .brand-text {
      min-width: 0; /* flex item: allow the wordmark to wrap at tiny widths */
    }

    .brand-title {
      font-size: clamp(0.78rem, 4vw, 1.02rem);
    }

    .brand-byline {
      font-size: clamp(0.9rem, 4.4vw, 1.15rem);
    }

    .peek-rusty {
      order: -1;
      flex-shrink: 0;
      width: clamp(48px, 18vw, 74px);
      margin: 0;
    }

    /* Percentage margin/clip keep the peek proportional at any width
       (margin % resolves against the parent's inline size). */
    .peek-rusty :global(img) {
      margin-bottom: -46%;
      clip-path: inset(0 0 31% 0); /* header no longer clips, so clip the art itself */
    }

    .mobile-nav summary {
      padding: 0.6rem 0.7rem;
    }
  }

  @media (max-width: 360px) {
    .burger-label {
      display: none; /* icon-only menu button; aria-label still names it */
    }
  }
</style>
