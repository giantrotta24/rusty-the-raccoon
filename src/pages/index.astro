---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import bookCover from '../assets/images/book-cover.png';
import riverScene from '../assets/images/raccoon-squeaks-river.jpeg';
import amazonLogo from '../assets/images/amazon-logo.png';

const amazonUrl =
  'https://www.amazon.com/Rusty-Raccoon-Scared-Michelle-Trotta/dp/B0CJ44D6NK/ref=tmm_pap_swatch_0?_encoding=UTF8&qid=1695085985&sr=8-1';

const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  '@id': 'https://www.rustytheraccoon.com/#book',
  name: 'Rusty the Raccoon is Scared of the Dark',
  bookFormat: 'https://schema.org/Paperback',
  inLanguage: 'en',
  url: 'https://www.rustytheraccoon.com/',
  image: new URL('/og-book-cover.jpg', Astro.site).href,
  author: {
    '@type': 'Person',
    '@id': 'https://www.rustytheraccoon.com/author/#michelle-trotta',
    name: 'Michelle Trotta',
    jobTitle: 'Speech-Language Pathologist',
    url: 'https://www.rustytheraccoon.com/author/',
  },
  illustrator: { '@type': 'Person', name: 'Alisha Uguccini' },
  publisher: {
    '@type': 'Organization',
    name: 'Fresh Beginnings Publishing',
    url: 'https://www.freshbeginningspublishing.com/',
  },
  sameAs: [
    'https://www.instagram.com/rusty_theraccoon/',
    'https://www.facebook.com/rustytheraccoonisscaredofthedark',
    'https://www.youtube.com/channel/UCOp3C0QBIaA5T6tU9N5aiCQ',
  ],
  offers: {
    '@type': 'Offer',
    url: amazonUrl,
    availability: 'https://schema.org/InStock',
  },
};
---

<BaseLayout
  title="Rusty the Raccoon is Scared of the Dark"
  description="A picture book by speech-language pathologist Michelle Trotta about Rusty the Raccoon, who finds the courage to face the dark with a little help from his friend Squeaks."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(bookSchema)} />
  <section class="hero section-teal">
    <div class="firefly-field" aria-hidden="true">
      <span class="firefly" style="left: 12%; top: 20%; animation-delay: 0.2s;"></span>
      <span class="firefly" style="left: 6%; top: 68%; animation-delay: 1.4s;"></span>
      <span class="firefly" style="left: 28%; top: 82%; animation-delay: 2.3s;"></span>
      <span class="firefly" style="left: 46%; top: 12%; animation-delay: 0.8s;"></span>
      <span class="firefly" style="left: 90%; top: 30%; animation-delay: 1.9s;"></span>
      <span class="firefly" style="left: 82%; top: 75%; animation-delay: 3s;"></span>
    </div>
    <div class="wrap hero-inner">
      <div class="hero-copy">
        <h1>Rusty the Raccoon is Scared of the Dark</h1>
        <div class="hero-cta">
          <p class="hero-cta-text">Click here to get your copy!</p>
          <svg
            class="hero-cta-arrow"
            aria-hidden="true"
            viewBox="0 0 48 44"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M10 4 C 10 22, 16 30, 34 32" />
            <path d="M26 24 L 35 32.5 L 25 38" />
          </svg>
          <a
            class="amazon-link"
            href={amazonUrl}
            target="_blank"
            rel="noreferrer noopener"
            aria-label="Buy Rusty the Raccoon is Scared of the Dark on Amazon"
          >
            <Image src={amazonLogo} alt="Available on Amazon" width={76} height={76} />
          </a>
        </div>
      </div>
      <div class="hero-art">
        <Image src={bookCover} alt="Rusty the Raccoon is Scared of the Dark — book cover" width={480} height={483} priority />
      </div>
    </div>
  </section>

  <section class="section intro">
    <div class="wrap intro-inner">
      <div class="intro-art">
        <Image src={riverScene} alt="Rusty the raccoon and Squeaks the squirrel floating on a log past the New York City skyline" width={420} height={420} />
      </div>
      <div class="intro-copy">
        <h2>Learn and play with Rusty and Squeaks!</h2>
        <p>Download coloring pages, mazes, word searches, crafts, and more.</p>
        <div class="teaser-links">
          <a class="btn btn-teal" href="/activities">Activities</a>
          <a class="btn btn-outline teal-outline" href="/resources">Resources</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 2.5rem;
    align-items: center;
    padding-block: clamp(3rem, 8vw, 5.5rem);
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    flex-wrap: wrap;
    margin-top: 1.6rem;
  }

  .hero-cta-text {
    font-family: var(--font-script);
    font-weight: 600;
    font-size: 1.9rem;
    line-height: 1.1;
    color: var(--color-cream-soft);
    margin: 0;
    flex-basis: 100%;
  }

  .hero-cta-arrow {
    width: 44px;
    height: 40px;
    color: var(--color-cream-soft);
    opacity: 0.9;
    margin-left: 1.6rem;
  }

  .amazon-link {
    display: inline-block;
    line-height: 0;
    border-radius: var(--radius-sm);
    box-shadow: 0 10px 26px -10px rgba(0, 0, 0, 0.55);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .amazon-link :global(img) {
    border-radius: var(--radius-sm);
    display: block;
  }

  .amazon-link:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 16px 32px -12px rgba(0, 0, 0, 0.6);
  }

  .hero-art {
    justify-self: center;
  }

  .hero-art :global(img) {
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 50px -18px rgba(0, 0, 0, 0.55);
  }

  @media (min-width: 780px) {
    .hero-inner {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  /* Mobile: the cover art IS the title, so let it lead poster-style and
     keep the h1 for screen readers/SEO only. CTA centers beneath it. */
  @media (max-width: 779px) {
    .hero-copy h1 {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }

    .hero-inner {
      gap: 2rem;
    }

    .hero-art {
      order: -1;
    }

    .hero-copy {
      text-align: center;
    }

    .hero-cta {
      justify-content: center;
      margin-top: 0.25rem;
    }

    .hero-cta-text {
      font-size: 1.75rem;
    }

    .hero-cta-arrow {
      margin-left: 0;
    }
  }

  .intro-inner {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }

  .intro-art {
    justify-self: center;
  }

  .intro-art :global(img) {
    border-radius: var(--radius-lg);
  }

  @media (min-width: 780px) {
    .intro-inner {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }

  .teaser-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.5rem;
  }

  .teal-outline {
    color: var(--color-teal);
  }

  .teal-outline:hover {
    background: rgba(20, 76, 83, 0.08);
  }
</style>
