---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import raccoonLogo from '../assets/images/raccoon-logo-transparent.png';
---

<BaseLayout
  title="Page not found — Rusty the Raccoon is Scared of the Dark"
  description="This page is lost in the dark. Find your way back to Rusty the Raccoon's home page, activities, and resources."
>
  <section class="section section-teal not-found">
    <div class="firefly-field" aria-hidden="true">
      <span class="firefly" style="left: 14%; top: 24%; animation-delay: 0.3s;"></span>
      <span class="firefly" style="left: 8%; top: 70%; animation-delay: 1.5s;"></span>
      <span class="firefly" style="left: 50%; top: 12%; animation-delay: 2.2s;"></span>
      <span class="firefly" style="left: 88%; top: 32%; animation-delay: 0.9s;"></span>
      <span class="firefly" style="left: 80%; top: 78%; animation-delay: 2.8s;"></span>
    </div>
    <div class="wrap not-found-inner">
      <Image src={raccoonLogo} alt="" width={193} height={287} class="not-found-rusty" />
      <h1>Uh oh — it's dark in here!</h1>
      <p>
        This page doesn't exist (or it wandered off with Squeaks). Don't be scared — the
        fireflies will light the way back.
      </p>
      <div class="not-found-links">
        <a class="btn btn-amber" href="/">Back home</a>
        <a class="btn btn-outline" href="/activities">Free activities</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 62vh;
    display: flex;
    align-items: center;
  }

  .not-found-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: grid;
    justify-items: center;
    gap: 1.1rem;
  }

  .not-found-inner :global(.not-found-rusty) {
    width: 130px;
    height: auto;
  }

  .not-found-inner p {
    max-width: 46ch;
    margin: 0;
  }

  .not-found-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    margin-top: 0.6rem;
  }
</style>
